# ── Spotify OAuth ──────────────────────────────────────────────────────────────
# Create at: https://developer.spotify.com/dashboard → Your App → Settings
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Must match the Redirect URI you set in Spotify Dashboard
SPOTIFY_REDIRECT_URI=http://localhost:3001/api/spotify/callback

# ── Ticketmaster Discovery API ─────────────────────────────────────────────────
# Create at: https://developer.ticketmaster.com → Get API Key
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed frontend origins (CORS)
FRONTEND_URL=http://localhost:3000
